 <script>
 function preencherTema(tema) {
 document.getElementById('temaEbook').value = `Um guia prático focado em ${tema}`;
 }
 async function enviarParaServidor() {
 const tema = document.getElementById('temaEbook').value;
 const token = document.getElementById('tokenPlataforma').value;
 
 const btnCriar = document.getElementById('btnCriar');
 const btnTexto = document.getElementById('btnTexto');
 const resultadoDiv = document.getElementById('resultado');
 if (!tema || !token) {
 alert("Por favor, digite o tema do e-book e insira o token da sua plataforma!");
 return;
 }
 btnCriar.disabled = true;
 btnCriar.classList.add('opacity-50', 'cursor-not-allowed');
 btnTexto.innerText = "A Inteligência Artificial está trabalhando... Aguarde.";
 try {
 const resposta = await fetch('/api/criar-produto', {
 method: 'POST',
 headers: { 'Content-Type': 'application/json' },
 body: JSON.stringify({ tema: tema, tokenPlataforma: token })
 });
 const dados = await resposta.json();
 if (dados.sucesso) {
 document.getElementById('linkCheckout').value = dados.checkoutUrl;
 document.getElementById('textoRoteiro').innerText = dados.videoScript;
 document.getElementById('textoGrupos').innerText = dados.marketingComunidades;
 
 resultadoDiv.classList.remove('hidden');
 window.scrollTo({ top: resultadoDiv.offsetTop, behavior: 'smooth' });
 } else {
 alert("Erro enviado pelo servidor: " + dados.erro);
 }
 } catch (error) {
 console.error("Erro na requisição:", error);
 alert("Não foi possível conectar ao servidor backend.");
 } finally {
 btnCriar.disabled = false;
 btnCriar.classList.remove('opacity-50', 'cursor-not-allowed');
 btnTexto.innerText = "Criar E-book & Vincular Produto";
 }
 }
 </script>
